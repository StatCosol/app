# ──────────────────────────────────────────────
# StatComPy Backend — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# Variables marked (required) must be set.

# ── App ──────────────────────────────────────
NODE_ENV=development          # development | production | test
PORT=3000

# ── Database (required) ─────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=changeme
DB_NAME=statcompy
DB_SSL=false                  # Set to 'true' for Azure PostgreSQL

# ── Auth (required) ─────────────────────────
# JWT_SECRET must be at least 20 characters
JWT_SECRET=change-this-to-a-random-secret-min-20-chars
# Access-token lifetime in seconds (default: 900 = 15 min); refresh token is 30 days
JWT_ACCESS_EXPIRES_SEC=900

# ── SMTP / Email ────────────────────────────
EMAIL_ENABLED=false           # Set to 'true' to enable outbound email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false             # 'true' for port 465 (SSL)
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@statcosol.com
SMTP_FROM_NAME=StatCo Solutions
SMTP_FROM_EMAIL=noreply@statcosol.com

# ── Frontend / CORS ─────────────────────────
FRONTEND_URL=http://localhost:4200
# Comma-separated origins allowed in production
CORS_ORIGINS=https://statcosol.com

# ── Seeding ──────────────────────────────────
SKIP_BOOTSTRAP_SEED=false     # Set to 'true' in production

# ── Admin ────────────────────────────────────
ADMIN_ALERT_EMAILS=           # Comma-separated admin notification emails
DEFAULT_SEED_PASSWORD=        # Password for seeded users (leave blank for auto-generated)

# ── AI / OpenAI ──────────────────────────────
# AES-256 encryption key for stored AI API keys (64 hex chars)
AI_ENCRYPTION_KEY=
