# Production environment template for docker-compose.yml
# Copy this file to .env.production and fill with real secrets.

# Required secrets
DB_PASS=REPLACE_WITH_STRONG_DB_PASSWORD
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_JWT_SECRET

# Optional mail and app settings
EMAIL_ENABLED=false
FRONTEND_URL=https://your-frontend-domain.example
CORS_ORIGINS=https://your-frontend-domain.example
